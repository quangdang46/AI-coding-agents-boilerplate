{
  "id": "github-pr-review",
  "name": "GitHub PR Review",
  "description": "Adds review-oriented prompts, skills, and MCP placeholders.",
  "version": "0.1.0",
  "dependsOn": [],
  "adds": {
    "agents": ["review-agent.agent.json"],
    "skills": ["review-pr"],
    "prompts": ["github-review.md"],
    "tools": ["mcp"]
  },
  "patches": [
    {
      "target": "agentkit.toml",
      "op": "merge",
      "path": "features.enabled",
      "value": ["github-pr-review"]
    },
    {
      "target": "agentkit.toml",
      "op": "merge",
      "path": "prompts.sections",
      "value": [".agent/prompts/sections/github-review.md"]
    },
    {
      "target": "agentkit.toml",
      "op": "merge",
      "path": "agents.enabled",
      "value": ["review-agent"]
    },
    {
      "target": "agentkit.toml",
      "op": "merge",
      "path": "skills.enabled",
      "value": ["review-pr"]
    },
    {
      "target": "agentkit.toml",
      "op": "merge",
      "path": "tools.enabled",
      "value": ["mcp"]
    }
  ]
}
