{
  "version": "1",
  "prerequisites": {
    "pythonProvingSliceRequired": true,
    "installerManifestDiscoveryRequired": true,
    "referenceIsolationRequired": true
  },
  "subsystems": [
    {
      "id": "core-engine",
      "paths": ["languages/typescript/runtime/engine", "references/source-typescript/SNAPSHOT.md"],
      "destination": "languages/typescript/runtime",
      "reason": "Reusable runtime kernel boundary from documented core extraction plan."
    },
    {
      "id": "core-prompts",
      "paths": ["languages/typescript/runtime/prompts", "references/source-typescript/SNAPSHOT.md"],
      "destination": "languages/typescript/runtime",
      "reason": "Prompt composition and file-backed prompt loading belong in runtime core."
    },
    {
      "id": "core-config",
      "paths": ["languages/typescript/runtime/config", "references/source-typescript/SNAPSHOT.md"],
      "destination": "languages/typescript/runtime",
      "reason": "Typed config contract and runtime loading are a language-pack core concern."
    },
    {
      "id": "core-registry",
      "paths": ["languages/typescript/runtime/registry", "references/source-typescript/SNAPSHOT.md"],
      "destination": "languages/typescript/runtime",
      "reason": "Registry construction for commands/tools/skills/agents/features is a reusable boundary."
    },
    {
      "id": "core-providers",
      "paths": ["languages/typescript/runtime/providers", "references/source-typescript/SNAPSHOT.md"],
      "destination": "languages/typescript/runtime",
