      "destination": "languages/typescript/template/base",
      "reason": "Current base template config is the seed for a generated TypeScript project."
    },
    {
      "id": "root-archive-metadata",
      "paths": [
        "references/typescript/README.md",
        "references/typescript/FEATURES.md",
        "references/typescript/CLAUDE.md",
        "references/typescript/package.json",
