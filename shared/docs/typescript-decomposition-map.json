        "references/typescript/assets/screenshot.png",
        "references/typescript/bun.lock",
        "references/typescript/.gitignore"
      ],
      "destination": "reference-only",
      "reason": "Archived free-code root docs, build metadata, lockfiles, and visual assets are evidence-only product surfaces and should not be re-extracted into the shipped AICD TypeScript pack."
    },
    {
      "id": "top-level-runtime-registries",
      "paths": ["references/source-typescript/SNAPSHOT.md"],
      "destination": "reference-only",
      "reason": "Still product-facing delegators over core shims; must be decomposed before extraction."
    },
    {
      "id": "main-cli-runtime",
      "paths": ["references/source-typescript/SNAPSHOT.md"],
      "destination": "reference-only",
      "reason": "Current interactive product runtime, not yet a clean language-pack ownership boundary."
    },
    {
      "id": "interactive-ui-screens",
      "paths": ["references/source-typescript/SNAPSHOT.md"],
      "destination": "future-feature-packs",
      "reason": "Large UI and hook surfaces should be decomposed into user-facing capability packs."
    },
    {
      "id": "skill-pipeline",
      "paths": ["references/source-typescript/SNAPSHOT.md"],
      "destination": "future-feature-packs",
      "reason": "Local skill discovery can inform core, but bundled skill pipelines remain optional."
    },
    {
      "id": "plugin-system",
      "paths": ["references/source-typescript/SNAPSHOT.md"],
      "destination": "future-feature-packs",
