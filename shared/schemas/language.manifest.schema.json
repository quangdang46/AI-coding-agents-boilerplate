{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicd.dev/schemas/language.manifest.schema.json",
  "title": "AICD Language Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "id",
    "displayName",
    "version",
    "description",
    "runtime",
    "templates",
    "supports"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "kind": {
      "type": "string",
      "const": "language-pack"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+([._-][a-z0-9]+)*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "object",
      "required": ["configFile"],
      "properties": {
        "configFile": {
          "type": "string",
          "minLength": 1
        },
        "projectMarkers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true,
          "default": []
        }
      },
      "additionalProperties": false
    },
    "templates": {
      "type": "object",
      "required": ["base"],
      "properties": {
        "base": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "supports": {
      "type": "object",
      "required": ["init", "featureAdd", "featureRemove", "doctor"],
      "properties": {
        "init": { "type": "boolean" },
        "featureAdd": { "type": "boolean" },
        "featureRemove": { "type": "boolean" },
        "doctor": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "cli": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "featureRegistry": {
      "type": "string",
      "minLength": 1
    },
    "extensions": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
