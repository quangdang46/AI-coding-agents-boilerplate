{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicd.dev/schemas/feature-pack.schema.json",
  "title": "AICD Feature Pack Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "id",
    "displayName",
    "version",
    "description",
    "appliesTo",
    "dependsOn",
    "adds",
    "patches"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "const": "1"
    },
    "kind": {
      "type": "string",
      "const": "feature-pack"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+([._-][a-z0-9]+)*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "appliesTo": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+([._-][a-z0-9]+)*$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "dependsOn": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dependency"
      }
    },
    "conflictsWith": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/conflict"
      },
      "default": []
    },
    "adds": {
      "type": "object",
      "properties": {
        "files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "agents": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "skills": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "prompts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "tools": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        },
        "commands": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "patches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/patch"
      }
    },
    "extensions": {
      "type": "object"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "dependency": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+([._-][a-z0-9]+)*$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "optional": {
          "type": "boolean",
          "default": false
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "configFragment": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "conflict": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+([._-][a-z0-9]+)*$"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warn"]
        }
      },
      "additionalProperties": false
    },
    "patch": {
      "type": "object",
      "required": ["target", "strategy"],
      "properties": {
        "target": {
          "type": "string",
          "minLength": 1
        },
        "strategy": {
          "type": "string",
          "enum": ["merge", "replace", "append"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "value": {}
      },
      "additionalProperties": false
    }
  }
}
