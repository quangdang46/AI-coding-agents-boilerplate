{
  "schemaVersion": "1",
  "kind": "language-pack",
  "id": "typescript",
  "displayName": "TypeScript",
  "version": "1.0.0",
  "description": "TypeScript language support for AICD",
  "runtime": {
    "configFile": "boilerplate.config.ts",
    "genericWorkspaceRoot": ".agents",
    "nativeWorkspaceRoot": ".<brand>",
    "projectMarkers": ["package.json", "tsconfig.json"]
  },
  "templates": {
    "base": "template/base"
  },
  "supports": {
    "init": true,
    "featureAdd": true,
    "doctor": true
  },
  "featureRegistry": "features/registry.json",
  "compatibility": {
    "cli": "^1.0.0"
  }
}
