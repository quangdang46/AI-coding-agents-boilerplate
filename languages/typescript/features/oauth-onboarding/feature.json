{
  "schemaVersion": "1",
  "kind": "feature-pack",
  "id": "oauth-onboarding",
  "displayName": "OAuth Onboarding",
  "description": "Adds an optional onboarding/auth workflow skill for TypeScript projects that need guided login and credential setup flows.",
  "version": "0.1.0",
  "appliesTo": ["typescript"],
  "dependsOn": [],
  "adds": {
    "agents": [],
    "skill": "use-oauth-onboarding",
    "prompts": [],
    "tools": []
  },
  "patches": [
    {
      "target": "boilerplate.config.ts",
      "strategy": "merge",
      "path": "features.enabled",
      "value": ["oauth-onboarding"]
    },
    {
      "target": "boilerplate.config.ts",
      "strategy": "merge",
      "path": "skills.enabled",
      "value": ["use-oauth-onboarding"]
    }
  ]
}
