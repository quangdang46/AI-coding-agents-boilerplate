  "version": "0.1.0",
  "appliesTo": ["typescript"],
  "dependsOn": [],
  "adds": {
    "agents": [],
    "skill": "use-plugin-runtime",
    "prompts": [],
    "tools": []
  },
  "patches": [
    {
      "target": "boilerplate.config.ts",
      "strategy": "merge",
      "path": "features.enabled",
      "value": ["plugin-runtime"]
    },
    {
      "target": "boilerplate.config.ts",
      "strategy": "merge",
      "path": "skills.enabled",
      "value": ["use-plugin-runtime"]
    }
  ]
}
