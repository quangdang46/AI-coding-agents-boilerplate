{
  "schemaVersion": "1",
  "kind": "feature-pack",
  "id": "github-pr-review",
  "displayName": "GitHub PR Review",
  "description": "Adds review-oriented prompts, skills, and MCP placeholders.",
  "version": "0.1.0",
  "appliesTo": ["python"],
  "dependsOn": [],
  "adds": {
    "agents": ["review-agent.md"],
    "skill": "review-pr",
    "prompts": [],
    "tools": ["mcp"]
  },
  "patches": [
    {
      "target": "agentkit.toml",
      "strategy": "merge",
      "path": "features.enabled",
      "value": ["github-pr-review"]
    },
    {
      "target": "agentkit.toml",
      "strategy": "merge",
      "path": "agents.enabled",
      "value": ["review-agent"]
    },
    {
      "target": "agentkit.toml",
      "strategy": "merge",
      "path": "skills.enabled",
      "value": ["review-pr"]
    },
    {
      "target": "agentkit.toml",
      "strategy": "merge",
      "path": "tools.enabled",
      "value": ["mcp"]
    }
  ]
}
