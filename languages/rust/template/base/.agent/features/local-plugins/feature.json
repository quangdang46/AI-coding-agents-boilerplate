{
  "schemaVersion": "1",
  "kind": "feature-pack",
  "id": "local-plugins",
  "displayName": "Local Plugins",
  "description": "Adds a local plugin workspace scaffold and records the plugin feature in .claw.json.",
  "version": "0.1.0",
  "appliesTo": ["rust"],
  "dependsOn": [],
  "adds": {
    "agents": [],
    "skills": [],
    "prompts": [],
    "tools": []
  },
  "patches": [
    {
      "target": ".claw.json",
      "strategy": "merge",
      "path": "features.enabled",
      "value": ["local-plugins"]
    }
  ]
}
